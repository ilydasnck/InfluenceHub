generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  instagramAccounts    InstagramAccount[]
  facebookPageAccounts FacebookPageAccount[]
  socialConnections    SocialConnection[]
  followerSnapshots    FollowerSnapshot[]
  posts                Post[]

  @@map("users")
}

enum PostStatus {
  SCHEDULED
  PROCESSING
  SUCCESS
  FAILED
  PARTIAL
}

enum PostTargetStatus {
  SCHEDULED
  SUCCESS
  FAILED
}

/// Günlük takipçi sayısı — haftalık/aylık değişim hesabı için
model FollowerSnapshot {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  accountKind     String   @map("account_kind")
  accountRefId    String   @map("account_ref_id")
  followerCount   Int      @map("follower_count")
  recordedAt      DateTime @default(now()) @map("recorded_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, accountKind, accountRefId, recordedAt])
  @@map("follower_snapshots")
}

/// Facebook Sayfa — Graph OAuth ile bağlanır
model FacebookPageAccount {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  pageId             String   @map("page_id")
  pageName           String   @map("page_name")
  pageAccessToken    String   @map("page_access_token")
  fanCount           Int      @default(0) @map("fan_count")
  pictureUrl         String?  @map("picture_url")
  pageLink           String?  @map("page_link")
  lastProfileSyncedAt DateTime? @map("last_profile_synced_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pageId])
  @@map("facebook_page_accounts")
}

/// Facebook / YouTube / TikTok (şimdilik OAuth yok; bağlantı kaydı + görüntüleme)
model SocialConnection {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  platform        String
  displayName     String   @map("display_name")
  handle          String
  followerCount   Int      @default(0) @map("follower_count")
  avatarUrl       String?  @map("avatar_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("social_connections")
}

model InstagramAccount {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  instagramUserId    String   @map("instagram_user_id")
  businessAccountId  String   @map("business_account_id")
  accessToken        String   @map("access_token")
  tokenExpiresAt     DateTime @map("token_expires_at")
  /// Graph API: username
  username           String?  @map("username")
  /// Profil görünen adı (name)
  name               String?  @map("name")
  profilePictureUrl  String?  @map("profile_picture_url")
  followersCount     Int      @default(0) @map("followers_count")
  /// Graph’ten son profil çekimi (sık yenilemeyi sınırlamak için)
  lastProfileSyncedAt DateTime? @map("last_profile_synced_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, instagramUserId])
  @@map("instagram_accounts")
}

model Post {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  title       String?
  caption     String
  hashtags    String?
  mediaType   String?    @map("media_type")
  mediaUrl    String?    @map("media_url")
  scheduledAt DateTime?  @map("scheduled_at")
  publishedAt DateTime?  @map("published_at")
  status      PostStatus @default(SCHEDULED)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  targets PostTarget[]

  @@index([userId, status, createdAt])
  @@map("posts")
}

model PostTarget {
  id            String           @id @default(uuid())
  postId        String           @map("post_id")
  accountKind   String           @map("account_kind")
  accountRefId  String           @map("account_ref_id")
  platform      String
  accountLabel  String?          @map("account_label")
  status        PostTargetStatus @default(SCHEDULED)
  errorMessage  String?          @map("error_message")
  externalPostId String?         @map("external_post_id")
  publishedAt   DateTime?        @map("published_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([accountKind, accountRefId])
  @@map("post_targets")
}
