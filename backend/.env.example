PORT=5000

# Istemciye verilen tam API tabani.
# Instagram medya paylasimi icin bu degerin herkese acik HTTPS URL olmasi gerekir
# (or. https://xxxx.ngrok-free.app). localhost/127.0.0.1 kullanmayin.
PUBLIC_API_URL=

# Instagram profil/takipçi yenileme aralığı (dakika, varsayılan 5)
# INSTAGRAM_PROFILE_SYNC_MINUTES=5

# JWT (kayıt/giriş token'ları için)
JWT_SECRET=

# Yerel admin (frontend: admin / admin, giriş API çağrısı yok) — isteklerde Authorization ile bu token
# LOCAL_ADMIN_TOKEN=influencehub_local_admin_dev

# Database (PostgreSQL bu makinede 5432'de dinlemeli)
# Hızlı başlatma — backend klasöründe: docker compose up -d
DATABASE_URL="postgresql://admin:secret@localhost:5432/influencehub"

# Instagram (artik OAuth ile otomatik alinir, manuel gerek yok)
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Facebook OAuth (Meta Developer Portal'dan alinir)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/instagram/callback

# Facebook Sayfa bağlantısı (Meta Developer → Uygulama → Facebook Girişi → Ayarlar → Geçerli OAuth yönlendirme URI)
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/facebook/callback

# OAuth sonrası tarayıcı yönlendirmesi (Next: http://localhost:3005)
FRONTEND_URL=http://localhost:3005

# Opsiyonel ama onerilir: Instagram icin medyayi public depolamaya yuklemek
# (Tunnel/domain engellerini asmak icin)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
